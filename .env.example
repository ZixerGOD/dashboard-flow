NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=*
REQUEST_TIMEOUT_MS=10000
CRM_REQUEST_TIMEOUT_MS=30000
SERVICE_NAME=uees-insights-middleware

META_VERIFY_TOKEN=change-me
META_APP_SECRET=change-me
META_ACCESS_TOKEN=change-me
META_GRAPH_VERSION=v20.0

CRM_BASE_URL=https://webservices.uees.edu.ec
CRM_ENDPOINT=/contactcenter/getData/getLeadsByCampaign
CRM_CAMPAIGN_QUERY_PARAM=c
MAKE_WEBHOOK_TOKEN=

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=dashboard-flow
DASHBOARD_AUTH_SECRET=change-me

APP_PUBLIC_URL=https://webservices.devmaniacs.net
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_PATH=/oauth/google-ads/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_API_VERSION=v20

META_AD_ACCOUNT_ID=

TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_API_BASE_URL=https://business-api.tiktok.com/open_api/v1.3

DATABASE_URL=postgresql://dashboard_flow:UEES2026%23@127.0.0.1:5432/dashboard_flow
DATABASE_SSL=false
DATABASE_POOL_MAX=10